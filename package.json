{
  "name": "seacms-qa-e2e",
  "version": "1.0.0",
  "description": "Playwright + TypeScript browser/API tests for the C-Track CMS (seacms-qa) deploy",
  "private": true,
  "scripts": {
    "test": "playwright test --project=chrome",
    "test:smoke": "playwright test --project=chrome tests/smoke/",
    "test:regression": "playwright test --project=chrome tests/regression/",
    "test:e2e": "playwright test --project=chrome tests/e2e/",
    "test:api": "playwright test --project=chrome tests/api/",
    "test:headed": "playwright test --project=chrome --headed",
    "report": "playwright show-report reports/html",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-playwright": "^2.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  }
}