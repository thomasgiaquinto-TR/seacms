# C-Track CMS (seacms-qa) test environment — copy to .env and fill in real values.
BASE_URL=https://seacms-qa.ctrack.thomsonreuters.com

# Admin / primary user
ADMIN_USER=
ADMIN_PASS=

# Standard user (optional)
STD_USER=
STD_PASS=

# API (optional) — REST base incl. /api suffix; token is an Authentication Token
# (User Profile > Add Token, see SEATC-27441) passed as the auth_token query param.
API_BASE_URL=https://seacms-qa.ctrack.thomsonreuters.com/api
API_TOKEN=

# Set to run the cross-browser matrix (chromium/firefox/webkit) in addition to chrome
ALL_BROWSERS=